<div class="container">
  <div class="row justify-content-center">
    <div class="col-12 col-md-6">
      <%= form_with model: @patient, local: true do |form| %>
        <div class="card shadow-sm">
          <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><%= @patient.new_record? ? "New Patient" : "Edit Patient" %></h5>
          </div>

          <div class="card-body">
            <div class="mb-3">
              <%= form.label :full_name, class: "form-label" %>
              <%= form.text_field :full_name, class: "form-control", placeholder: "Enter full name", required: true %>
            </div>

            <div class="mb-3">
              <%= form.label :age, class: "form-label" %>
              <%= form.number_field :age, class: "form-control", placeholder: "Enter age", required: true %>
            </div>

            <div class="mb-3">
              <%= form.label :diagnosis, class: "form-label" %>
              <%= form.text_area :diagnosis, class: "form-control", placeholder: "Enter diagnosis", rows: 3, required: true %>
            </div>

            <div class="mb-3">
              <%= form.label :city, class: "form-label" %>
              <%= form.text_field :city, class: "form-control", placeholder: "Enter city"%>
            </div>

            <div class="mb-3">
              <%= form.label :address, class: "form-label" %>
              <%= form.text_area :address, class: "form-control", placeholder: "Enter address", rows: 3 %>
            </div>
          </div>

          <div class="card-footer text-end">
            <%= link_to 'Cancel', patients_path, class: "btn btn-secondary me-2" %>
            <%= form.submit class: "btn btn-primary" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
