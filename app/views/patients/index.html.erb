<div class="container text-center">
  <% if current_user.admin? %>
    <div class="text-end me-4 mb-3">
      <%= link_to "Create User", new_user_registration_path, class: "btn btn-success" %>
    </div>
  <% end %>
  <% if current_user.admin? || current_user.doctor? %>
    <%= render "patient_data" %>
  <% end %>

  <h2 class="my-4">Patient List</h2>

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0">Patients</h3>

    <% if can?(:create, Patient) %> 
      <%= link_to 'Add New Patient', new_patient_path, class: 'btn btn-primary' %>
    <% end %>
  </div>

  <div class="d-flex justify-content-end mb-4">
    <%= form_with url: patients_path, method: :get, local: true, html: { class: "w-30" } do %>
      <div class="input-group" >
        <%= text_field_tag :query, params[:query], placeholder: "Search by name or diagnosis...", class: "form-control" %>
        <button class="btn btn-outline-primary" type="submit">Search</button>
      </div>
    <% end %>
  </div>  

  <% if @patients.empty? %>
    <div class="alert alert-warning" role="alert">
      No patients found.
    </div>
  <% else %>
    <div class="table-responsive d-flex justify-content-center">
      <table class="table table-bordered table-hover table-striped align-middle">
        <thead class="table-dark">
          <tr>
            <th>Sr. no.</th>
            <th>Name</th>
            <th>Age</th>
            <th>Diagnosis</th>
            <th>City</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @patients.each_with_index do |patient, index| %>
            <tr>
              <td><%= index + 1 %></td>
              <td><%= patient.full_name.titleize %></td>
              <td><%= patient.age %></td>
              <td><%= patient.diagnosis %></td>
              <td><%= patient.city %></td>
              <td>
                <div class="d-flex justify-content-center gap-2">
                  <%= link_to 'Show', patient_path(patient), class: 'btn btn-info btn-sm' %>

                  <% if can?(:update, patient) %> 
                    <%= link_to 'Edit', edit_patient_path(patient), class: 'btn btn-warning btn-sm' %>
                  <% end %>

                  <% if can?(:destroy, patient) %>
                  <%= button_to 'Delete', patient_path(patient), 
                      method: :delete,
                      data: { confirm: 'Are you sure you want to delete this patient?' }, 
                      class: 'btn btn-danger btn-sm' %>
                <% end %>
                
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

  <!-- Pagination -->
  <div class="d-flex justify-content-center">
    <%= paginate @patients %>
  </div>
</div>
