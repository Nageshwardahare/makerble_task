<!-- <h2 class="text-center mt-4 mb-4">Makerble  </h2> -->
<div class="container mt-3">
  <div class="row justify-content-center">
    <div class="col-md-6">

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: 'form-signup' }) do |f| %>
      <h2 class="text-center mb-4">Create User</h2>

        <!-- Error Messages -->
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="mb-3">
          <%= f.label :full_name, class: 'form-label' %>
          <%= f.text_field :full_name, autofocus: true, autocomplete: "name", class: 'form-control', placeholder: 'Enter your full name' %>
        </div>
        
        <div class="mb-3">
          <%= f.label :dob, class: 'form-label' %>
          <%= f.date_field :dob, autofocus: true, autocomplete: "dob", class: 'form-control'%>
        </div>
        <!-- Email Field -->
        <div class="mb-3">
          <%= f.label :email, class: 'form-label' %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: 'form-control', placeholder: 'Enter your email' %>
        </div>

        <!-- Password Field -->
        <div class="mb-3">
          <%= f.label :password, class: 'form-label' %>
          <% if @minimum_password_length %>
            <small class="text-muted">(Minimum <%= @minimum_password_length %> characters)</small>
          <% end %>
          <%= f.password_field :password, autocomplete: "new-password", class: 'form-control', placeholder: 'Choose a password' %>
        </div>

        <!-- Password Confirmation Field -->
        <div class="mb-3">
          <%= f.label :password_confirmation, class: 'form-label' %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: 'form-control', placeholder: 'Confirm your password' %>
        </div>

        <div class="mb-3">
          <%= f.label :role, class: 'form-label' %>
          <%= f.select :role, User.roles.keys.map { |r| [r.titleize, r] }, {}, class: 'form-select' %>
        </div>

        <!-- Submit Button -->
        <div class="d-grid gap-2">
          <%= f.submit "Sign Up", class: 'btn btn-primary btn-lg' %>
        </div>
      <% end %>

    </div>
  </div>
</div>

